generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ... (mantenha o generator e datasource como estão)

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role
  status    Boolean?  @default(true)  
  createdAt DateTime  @default(now())
  payments  Payment[]

  @@map("users")
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String    // Nome da empresa/fornecedor
  cnpj      String?   @unique // Opcional, mas recomendado para MySQL
  payments  Payment[] // Relação inversa: um fornecedor tem vários pagamentos

  @@map("suppliers")
}

model Payment {
  id              Int      @id @default(autoincrement())
  description     String
  amount          Float
  status          Status   @default(PENDENTE)
  rejectionReason String?
  authorizerName  String?
  
  createdById     Int
  createdBy       User     @relation(fields: [createdById], references: [id])

  supplierId      Int      // Campo que guarda o ID do fornecedor
  supplier        Supplier @relation(fields: [supplierId], references: [id])

  createdAt       DateTime @default(now())

  @@index([createdById], map: "payments_createdById_fkey")
  @@index([supplierId], map: "payments_supplierId_fkey") // Índice para performance
  @@map("payments")
}

enum Role {
  REGISTRO
  AUTORIZACAO
  ADMIN

  @@map("roles")
}

enum Status {
  PENDENTE
  APROVADO
  REJEITADO

  @@map("statuses")
}
