generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role
  createdAt DateTime  @default(now())
  status    Boolean?  @default(true)
  payments  Payment[]

  @@map("users")
}

model Supplier {
  id       Int       @id @default(autoincrement())
  name     String
  cnpj     String?   @unique
  payments Payment[]

  @@map("suppliers")
}

model Payment {
  id              Int      @id @default(autoincrement())
  description     String
  amount          Float
  status          Status   @default(PENDENTE)
  rejectionReason String?
  authorizerName  String?
  createdById     Int
  createdAt       DateTime @default(now())
  supplierId      Int
  createdBy       User     @relation(fields: [createdById], references: [id])
  supplier        Supplier @relation(fields: [supplierId], references: [id])

  @@index([createdById], map: "payments_createdById_fkey")
  @@index([supplierId], map: "payments_supplierId_fkey")
  @@map("payments")
}

enum Role {
  REGISTRO
  AUTORIZACAO
  ADMIN

  @@map("roles")
}

enum Status {
  PENDENTE
  AUTORIZADO
  REJEITADO

  @@map("statuses")
}
